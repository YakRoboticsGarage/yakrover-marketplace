# ── Stripe (required for live payment mode) ──────────────────────────
# Get from dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# ── Auction settings ─────────────────────────────────────────────────
# SQLite database path (default: :memory: — in-memory, lost on restart)
AUCTION_DB_PATH=:memory:

# Ed25519 signing mode (default: hmac for backward compat)
# SIGNING_MODE=ed25519

# Connect account for robot operator payouts (created via Stripe Connect)
# STRIPE_OPERATOR_ACCOUNT=acct_xxx

# ── MCP server auth (optional) ───────────────────────────────────────
MCP_BEARER_TOKEN=

# ── ngrok (free static domain from https://dashboard.ngrok.com/domains) ──
NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-name-here.ngrok-free.dev

# ── ERC-8004 Registration (Ethereum Sepolia) ─────────────────────────
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
WALLET_ADDRESS=
SIGNER_PVT_KEY=
PINATA_JWT=

# ── Blockchain integration tests (optional — only for pytest -m blockchain) ──
# Free public endpoint; paid options (Alchemy, Infura) for higher rate limits
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Fake rover simulator (optional — defaults to http://localhost:8080)
FAKEROVER_URL=http://localhost:8080
